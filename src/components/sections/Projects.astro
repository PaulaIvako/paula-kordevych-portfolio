---
import projectsData from '../../data/projects.json';
const { projects } = projectsData;

const colorClasses: Record<string, string> = {
  yellow: 'bg-project-yellow/50',
  green: 'bg-project-green/50',
  purple: 'bg-project-purple/50'
};
---

<section id="projekty" class="mb-20 reveal">
  <h2 class="font-aboreto text-3xl md:text-4xl text-text dark:text-text-dark text-center mb-10">
    UX UI PROJEKTY
  </h2>
  
  <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
    {projects.map((project) => (
      <article class="group bg-surface-strong dark:bg-surface-strong-dark rounded-2xl overflow-hidden border border-surface-border dark:border-white/[0.12] shadow-md hover:shadow-lg transition-all duration-300 hover:-translate-y-1 flex flex-col min-h-[480px]">
        <!-- Card top with color -->
        <div class={`h-48 ${colorClasses[project.color] || 'bg-gray-200'} flex items-center justify-center relative overflow-hidden`}>
          <div class="absolute inset-0 bg-gradient-to-t from-black/10 to-transparent"></div>
        </div>
        
        <!-- Card bottom -->
        <div class="p-6 flex flex-col h-full">
          <h3 class="font-aboreto text-2xl md:text-3xl text-text dark:text-text-dark mb-3">
            {project.title}
          </h3>

          <div class="flex flex-wrap gap-2 mb-4">
            <span class="px-3 py-1 bg-accent-blue/10 text-accent-blue text-xs font-montserrat font-medium rounded-full">
              {project.type}
            </span>
            {project.tags.map((tag) => (
              <span class="px-3 py-1 bg-surface dark:bg-surface-dark text-muted dark:text-gray-300 text-xs font-montserrat rounded-full border border-surface-border dark:border-white/[0.12]">
                {tag}
              </span>
            ))}
          </div>

          <p class="font-montserrat text-sm text-muted dark:text-gray-300 mb-6 flex-grow">
            {project.description}
          </p>

          <a
            href={`/projects/${project.id}`}
            class="inline-flex items-center px-4 py-2 text-text dark:text-text-dark font-montserrat font-medium text-sm rounded-lg border border-text dark:border-text-dark hover:text-accent-blue hover:border-accent-blue transition-colors mt-auto w-fit"
          >
            Więcej
          </a>
        </div>
      </article>
    ))}
  </div>

  <!-- Główny przycisk pod sekcją -->
  <div class="text-center mt-10">
    <a
      href="/projects"
      class="inline-flex items-center px-8 py-3 text-text dark:text-text-dark font-montserrat font-medium text-sm rounded-lg border border-text dark:border-text-dark hover:text-accent-blue hover:border-accent-blue transition-colors"
    >
      Zobacz wszystkie projekty
    </a>
  </div>
</section>
