---
import projectsData from '../../data/projects.json';
const { projects, visualWork } = projectsData;

const colorClasses: Record<string, string> = {
  yellow: 'bg-project-yellow/50',
  green: 'bg-project-green/50',
  purple: 'bg-project-purple/50'
};

// Separate featured project (first one) from others
const featuredProject = projects[0];
const otherProjects = projects.slice(1);
---

<section id="projekty" class="mb-16 reveal">
  <h2 class="font-aboreto text-2xl sm:text-3xl md:text-4xl text-text dark:text-text-dark text-center mb-8 sm:mb-12">
    UX UI PROJEKTY
  </h2>

  <!-- Bento Grid Layout -->
  <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-4 sm:gap-6">
    
    {/* Featured Project - Large Card */}
    <article class="group md:col-span-2 lg:col-span-2 lg:row-span-2 bg-gradient-to-br from-surface-strong to-surface dark:from-surface-strong-dark dark:to-surface-dark rounded-2xl overflow-hidden border border-surface-border dark:border-white/[0.12] shadow-md hover:shadow-xl transition-all duration-300 hover:-translate-y-1 flex flex-col">
      {/* Card top with color - taller for featured */}
      <div class={`h-48 sm:h-64 lg:h-80 ${colorClasses[featuredProject.color] || 'bg-gray-200'} flex items-center justify-center relative overflow-hidden`}>
        <div class="absolute inset-0 bg-gradient-to-t from-black/10 to-transparent"></div>
        <span class="font-aboreto text-4xl sm:text-5xl lg:text-6xl text-text/20 dark:text-white/10">{featuredProject.title}</span>
      </div>

      {/* Card bottom */}
      <div class="p-5 sm:p-8 flex flex-col flex-grow">
        <h3 class="font-aboreto text-2xl sm:text-3xl lg:text-4xl text-text dark:text-text-dark mb-3">
          {featuredProject.title}
        </h3>

        <div class="flex flex-wrap gap-2 mb-4">
          <span class="px-3 py-1 bg-accent-blue/10 dark:bg-[#DB5700]/10 text-accent-blue dark:text-[#DB5700] text-xs font-montserrat font-medium rounded-full">
            {featuredProject.type}
          </span>
          {featuredProject.tags.map((tag) => (
            <span class="px-3 py-1 bg-surface dark:bg-surface-dark text-muted dark:text-gray-300 text-xs font-montserrat rounded-full border border-surface-border dark:border-white/[0.12]">
              {tag}
            </span>
          ))}
        </div>

        <p class="font-montserrat text-sm sm:text-base text-muted dark:text-gray-300 mb-6 flex-grow leading-relaxed">
          {featuredProject.description}
        </p>

        <a
          href={`/projects/${featuredProject.id}`}
          class="inline-flex items-center px-5 py-2.5 bg-accent-blue dark:bg-[#DB5700] text-white font-montserrat font-medium text-sm rounded-lg hover:shadow-lg hover:shadow-accent-blue/25 dark:hover:shadow-[#DB5700]/25 transition-all duration-300 w-fit"
        >
          Zobacz case study
          <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4 ml-2" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3" />
          </svg>
        </a>
      </div>
    </article>

    {/* Other Projects - Stacked Smaller Cards */}
    {otherProjects.map((project) => (
      <article class="group bg-gradient-to-br from-surface-strong to-surface dark:from-surface-strong-dark dark:to-surface-dark rounded-2xl overflow-hidden border border-surface-border dark:border-white/[0.12] shadow-md hover:shadow-lg transition-all duration-300 hover:-translate-y-1 flex flex-col">
        {/* Card top with color */}
        <div class={`h-32 sm:h-40 ${colorClasses[project.color] || 'bg-gray-200'} flex items-center justify-center relative overflow-hidden`}>
          <div class="absolute inset-0 bg-gradient-to-t from-black/10 to-transparent"></div>
          <span class="font-aboreto text-2xl sm:text-3xl text-text/20 dark:text-white/10">{project.title}</span>
        </div>

        {/* Card bottom */}
        <div class="p-4 sm:p-5 flex flex-col flex-grow">
          <h3 class="font-aboreto text-lg sm:text-xl text-text dark:text-text-dark mb-2">
            {project.title}
          </h3>

          <div class="flex flex-wrap gap-1.5 mb-3">
            <span class="px-2.5 py-0.5 bg-accent-blue/10 dark:bg-[#DB5700]/10 text-accent-blue dark:text-[#DB5700] text-[10px] font-montserrat font-medium rounded-full">
              {project.type}
            </span>
            {project.tags.slice(0, 1).map((tag) => (
              <span class="px-2.5 py-0.5 bg-surface dark:bg-surface-dark text-muted dark:text-gray-300 text-[10px] font-montserrat rounded-full border border-surface-border dark:border-white/[0.12]">
                {tag}
              </span>
            ))}
          </div>

          <p class="font-montserrat text-xs sm:text-sm text-muted dark:text-gray-300 mb-4 flex-grow line-clamp-3">
            {project.description}
          </p>

          <a
            href={`/projects/${project.id}`}
            class="inline-flex items-center px-3 py-1.5 text-text dark:text-text-dark font-montserrat font-medium text-xs rounded-lg border border-text dark:border-text-dark hover:text-accent-blue hover:border-accent-blue dark:hover:text-[#DB5700] dark:hover:border-[#DB5700] transition-all duration-300 w-fit"
          >
            Więcej
          </a>
        </div>
      </article>
    ))}
  </div>

  {/* Visual Work Section */}
  <div class="mt-16 sm:mt-20">
    <h2 class="font-aboreto text-2xl sm:text-3xl md:text-4xl text-text dark:text-text-dark text-center mb-8 sm:mb-12">
      GRAPHIC & BRANDING
    </h2>
    
    <div class="grid grid-cols-1 md:grid-cols-2 gap-6 sm:gap-8">
      {visualWork.map((work) => (
        <a 
          href={work.link}
          target="_blank"
          rel="noreferrer"
          class="group bg-gradient-to-br from-surface-strong to-surface dark:from-surface-strong-dark dark:to-surface-dark rounded-2xl overflow-hidden border border-surface-border dark:border-white/[0.12] shadow-md hover:shadow-xl transition-all duration-300 hover:-translate-y-1"
        >
          {/* Image */}
          <div class="aspect-[4/3] overflow-hidden">
            <img 
              src={work.image} 
              alt={work.title}
              class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500"
            />
          </div>
          
          {/* Content */}
          <div class="p-5 sm:p-6">
            <span class="text-accent-blue dark:text-[#DB5700] text-xs font-montserrat font-medium uppercase tracking-wider">
              {work.category}
            </span>
            <h3 class="font-aboreto text-xl sm:text-2xl text-text dark:text-text-dark mt-2 mb-2">
              {work.title}
            </h3>
            <p class="font-montserrat text-sm text-muted dark:text-gray-300">
              {work.description}
            </p>
          </div>
        </a>
      ))}
    </div>
  </div>
</section>
