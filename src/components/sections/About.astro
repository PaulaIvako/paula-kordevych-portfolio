---
import { Image } from 'astro:assets';
import projectsData from '../../data/projects.json';
import paulaImage from '../../assets/about/paula.png';
const { about } = projectsData;
---

<section id="o-mnie" class="py-16 md:py-24 px-6 md:px-12 lg:px-20 reveal">
  <h2 class="font-aboreto text-3xl md:text-4xl text-text dark:text-text-dark text-center mb-8">
    O MNIE
  </h2>
  
  <div class="flex flex-col lg:flex-row items-center gap-12">
    <div class="w-full lg:max-w-2xl space-y-6">
      <p class="font-aboreto text-lg md:text-xl text-text dark:text-text-dark tracking-wide">
        {about.kicker}
      </p>

      {about.paragraphs.map((paragraph) => (
        <p class="font-montserrat text-base text-muted dark:text-gray-300 leading-relaxed">
          {paragraph}
        </p>
      ))}
    </div>
    
    <div class="w-full lg:w-1/3 max-w-sm">
      <div class="relative">
        <div class="absolute inset-0 bg-gradient-to-br from-accent-blue/20 to-accent-pink/20 rounded-2xl transform rotate-3"></div>
        <Image 
          src={paulaImage}
          alt="Paula Kordevych - zdjęcie profilowe"
          width={400}
          height={500}
          class="relative rounded-2xl shadow-lg w-full h-auto object-cover"
        />
      </div>
    </div>
  </div>
</section>
