---
import projectsData from '../../data/projects.json';
const { about } = projectsData;
---

<section id="o-mnie" class="py-16 md:py-20 px-6 md:px-12 lg:px-20 reveal">
  <div class="max-w-4xl mx-auto">
    
    <!-- Nagłówek -->
    <h2 class="font-aboreto text-3xl md:text-4xl text-text dark:text-text-dark text-center mb-10 md:mb-12">
      O MNIE
    </h2>
    
    <!-- Bento Grid - tylko tekst -->
    <div class="grid grid-cols-1 md:grid-cols-2 gap-4 md:gap-5">
      
      <!-- Kafelek 1: Kicker - szeroki -->
      <div class="md:col-span-2 bg-surface dark:bg-surface-dark rounded-2xl p-6 md:p-8 border border-line dark:border-line-dark">
        <p class="font-aboreto text-xl md:text-2xl lg:text-3xl text-text dark:text-text-dark tracking-wide leading-tight">
          {about.kicker}
        </p>
      </div>
      
      <!-- Kafelek 2: Paragraf 1 -->
      <div class="bg-surface/50 dark:bg-surface-dark/50 rounded-2xl p-6 md:p-8 border border-line dark:border-line-dark">
        <p class="font-montserrat text-sm md:text-base text-muted dark:text-gray-300 leading-relaxed">
          {about.paragraphs[0]}
        </p>
      </div>
      
      <!-- Kafelek 3: Paragraf 2 -->
      <div class="bg-surface/50 dark:bg-surface-dark/50 rounded-2xl p-6 md:p-8 border border-line dark:border-line-dark">
        <p class="font-montserrat text-sm md:text-base text-muted dark:text-gray-300 leading-relaxed">
          {about.paragraphs[1]}
        </p>
      </div>
      
      <!-- Kafelek 4: Paragraf 3 - szeroki -->
      <div class="md:col-span-2 bg-surface dark:bg-surface-dark rounded-2xl p-6 md:p-8 border border-line dark:border-line-dark">
        <p class="font-montserrat text-sm md:text-base text-muted dark:text-gray-300 leading-relaxed">
          {about.paragraphs[2]}
        </p>
      </div>
      
    </div>
    
  </div>
</section>
