---
import projectsData from '../../data/projects.json';
const { process } = projectsData;
---

<section id="proces" class="py-16 md:py-24 px-6 md:px-12 lg:px-20 reveal">
  <h2 class="font-aboreto text-3xl md:text-4xl text-text dark:text-text-dark text-center mb-4">
    PROCES PROJEKTOWY
  </h2>
  
  <div class="max-w-5xl mx-auto">
    <p class="font-montserrat text-base text-muted dark:text-gray-300 mb-8 max-w-3xl">
      {process.intro}
    </p>

    <ol class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
      {process.steps.map((step, index) => (
        <li class="flex gap-4">
          <span class="inline-flex items-center justify-center w-12 h-12 rounded-lg bg-accent-blue/10 text-accent-blue font-aboreto text-xl flex-shrink-0">
            {step.index}
          </span>
          <div class="pt-1">
            <strong class="block font-montserrat text-base font-medium text-text dark:text-text-dark mb-2">
              {step.title}
            </strong>
            <span class="font-montserrat text-sm text-muted dark:text-gray-300 leading-relaxed">
              {step.description}
            </span>
          </div>
        </li>
      ))}
    </ol>
  </div>
</section>
