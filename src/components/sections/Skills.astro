---
import projectsData from '../../data/projects.json';
const { skills } = projectsData;
---

<section id="umiejetnosci" class="py-16 md:py-24 px-6 md:px-12 lg:px-20 reveal">
  <h2 class="font-aboreto text-3xl md:text-4xl text-text dark:text-text-dark text-center mb-4">
    UMIEJĘTNOŚCI
  </h2>
  
  <div class="max-w-5xl mx-auto">
    <!-- Tools -->
    <div class="grid grid-cols-2 md:grid-cols-4 gap-3 sm:gap-4 mb-8">
      {skills.tools.map((tool) => (
        <div class="text-center p-3 sm:p-6 bg-gradient-to-br from-surface to-surface-strong dark:from-surface-dark dark:to-surface-strong-dark rounded-xl border border-surface-border dark:border-white/[0.12] hover:shadow-md transition-all duration-300">
          <span class="inline-flex items-center justify-center w-10 h-10 sm:w-12 sm:h-12 rounded-lg bg-gradient-to-br from-accent-blue/20 to-accent-blue/5 dark:from-[#DB5700]/20 dark:to-[#DB5700]/5 text-accent-blue dark:text-[#DB5700] font-montserrat font-bold text-base sm:text-lg mb-2 sm:mb-3">
            {tool.icon}
          </span>
          <h3 class="font-montserrat text-xs sm:text-sm font-medium text-text dark:text-text-dark mb-1">
            {tool.name}
          </h3>
          <p class="font-montserrat text-[10px] sm:text-xs text-muted dark:text-gray-300 leading-tight">
            {tool.description}
          </p>
        </div>
      ))}
    </div>
    
    <!-- Skill categories -->
    <div class="grid grid-cols-1 md:grid-cols-3 gap-6 md:gap-4">
      {skills.categories.map((category) => (
        <article class="bg-surface dark:bg-surface-dark rounded-xl p-5 border border-surface-border dark:border-white/[0.12]">
          <h3 class="font-montserrat text-sm font-medium text-text dark:text-text-dark mb-3 pb-2 border-b border-black/[0.06] dark:border-white/[0.12]">
            {category.title}
          </h3>
          <ul class="space-y-1.5">
            {category.items.map((item) => (
              <li class="font-montserrat text-sm text-muted dark:text-gray-300 flex items-center gap-2">
                <span class="w-1.5 h-1.5 rounded-full bg-accent-blue flex-shrink-0"></span>
                <span>{item}</span>
              </li>
            ))}
          </ul>
        </article>
      ))}
    </div>
  </div>
</section>
