---
import projectsData from '../../data/projects.json';
const { pov } = projectsData;
---

<section id="pov" class="py-12 sm:py-16 md:py-24 px-4 sm:px-6 md:px-12 lg:px-20 reveal">
  <h2 class="font-aboreto text-2xl sm:text-3xl md:text-4xl text-text dark:text-text-dark text-center mb-6 sm:mb-4">
    JAK MYŚLĘ JAKO DESIGNER
  </h2>

  <div class="max-w-3xl mx-auto relative pl-4 sm:pl-8">
    <div class="space-y-6 sm:space-y-8">
      {pov.paragraphs.map((paragraph, index) => (
        <div class="relative flex items-start gap-3 sm:gap-6">
          {/* Kontener na linię i kropkę */}
          <div class="relative flex flex-col items-center pt-1 flex-shrink-0">
            {/* Linia górna */}
            {index > 0 && <div class="absolute bottom-1/2 top-[-24px] sm:top-[-32px] w-px bg-line dark:bg-line-dark"></div>}

            {/* Kropka na linii */}
            <div class="w-2.5 h-2.5 sm:w-3 sm:h-3 rounded-full bg-accent-blue relative z-10"></div>

            {/* Linia dolna */}
            {index < pov.paragraphs.length - 1 && <div class="absolute top-1/2 bottom-[-24px] sm:bottom-[-32px] w-px bg-line dark:bg-line-dark"></div>}
          </div>

          {/* Tekst */}
          <p class="font-montserrat text-sm sm:text-base text-text dark:text-text-dark leading-relaxed pt-0 break-words">
            {paragraph}
          </p>
        </div>
      ))}
    </div>
  </div>
</section>
