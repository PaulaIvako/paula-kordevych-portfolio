---
const navItems = [
  { label: 'Strona główna', shortLabel: 'Start', href: '/', id: 'home' },
  { label: 'Projekty', shortLabel: 'Projekty', href: '/#projekty', id: 'projects' },
  { label: 'O mnie', shortLabel: 'O mnie', href: '/#o-mnie', id: 'about' },
  { label: 'Kontakt', shortLabel: 'Kontakt', href: '/#kontakt', id: 'contact' }
];

const currentPath = Astro.url.pathname;
const isHomePage = currentPath === '/';
const isCaseStudy = currentPath.startsWith('/projects/');
---

<header class="sticky top-0 z-50 h-[62px] border-b border-line dark:border-line-dark bg-nav/70 dark:bg-nav-dark/80 backdrop-blur-nav transition-colors duration-300">
  <div class="max-w-layout mx-auto h-full flex items-center px-3 sm:px-6 relative">
    <!-- Mobile nav centered -->
    <nav class="flex sm:hidden items-center justify-center gap-0 text-[10px] tracking-wide w-full" aria-label="Nawigacja mobile">
      {navItems.map((item, index) => (
        <>
          {index > 0 && <span class="text-muted/30 px-0.5">|</span>}
          <a
            href={item.href}
            class="text-text dark:text-text-dark hover:text-accent-blue dark:hover:text-[#DB5700] transition-colors whitespace-nowrap py-2 px-1"
          >
            {item.shortLabel}
          </a>
        </>
      ))}
    </nav>

    <nav class="hidden sm:flex items-center gap-2 text-xs tracking-wide mx-auto" aria-label="Nawigacja">
      {navItems.map((item) => (
        <a
          href={item.href}
          class={`transition-all duration-200 whitespace-nowrap py-2 px-4 text-[11px] md:text-xs rounded-lg border ${
            (item.id === 'home' && isHomePage && !isCaseStudy) || (item.id === 'projects' && isCaseStudy)
              ? 'border-accent-blue dark:border-[#DB5700] text-accent-blue dark:text-[#DB5700] font-medium'
              : 'border-text dark:border-text-dark text-text dark:text-text-dark hover:border-accent-blue dark:hover:border-[#DB5700] hover:text-accent-blue dark:hover:text-[#DB5700]'
          }`}
        >
          {item.label}
        </a>
      ))}
    </nav>

    <button
      id="theme-toggle"
      class="absolute right-3 sm:right-6 w-9 h-9 sm:w-10 sm:h-10 rounded-full bg-surface-strong dark:bg-surface-strong-dark border border-surface-border dark:border-white/[0.12] flex items-center justify-center hover:scale-110 transition-transform"
      aria-label="Przełącz tryb ciemny"
    >
      <span id="theme-icon" class="text-base sm:text-lg">🌙</span>
    </button>
  </div>
</header>

<style>
  .scrollbar-hide::-webkit-scrollbar {
    display: none;
  }
  .scrollbar-hide {
    -ms-overflow-style: none;
    scrollbar-width: none;
  }
</style>
