---
import type { CollectionEntry } from 'astro:content';

interface Props {
  title: string;
  subtitle: string;
  problem?: string;
  scope?: string;
  reflection?: string;
  themeColor?: string;
  images: string[];
  color?: string;
}

const { 
  title, 
  subtitle, 
  problem, 
  scope, 
  reflection,
  themeColor = "#F4F2EA",
  images = [],
  color = "yellow"
} = Astro.props;

const colorClasses: Record<string, string> = {
  yellow: 'bg-project-yellow/30',
  green: 'bg-project-green/30',
  purple: 'bg-project-purple/30'
};

const themeBgClasses: Record<string, string> = {
  yellow: 'bg-[#F4F2EA]',
  green: 'bg-[#FFFCEE]',
  purple: 'bg-[#4A3D61]'
};
---

<!DOCTYPE html>
<html lang="pl">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title} | Paula Kordevych</title>
    <meta name="description" content={`Case study projektu ${title} - Paula Kordevych UX/UI Designer`} />
    <meta name="theme-color" content={themeColor} />
    
    <!-- Favicons -->
    <link rel="apple-touch-icon" sizes="180x180" href="/Favicon/apple-touch-icon.png" />
    <link rel="icon" type="image/png" sizes="32x32" href="/Favicon/favicon-32x32.png" />
    <link rel="icon" type="image/png" sizes="16x16" href="/Favicon/favicon-16x16.png" />
    <link rel="manifest" href="/Favicon/site.webmanifest" />
    <link rel="shortcut icon" href="/Favicon/favicon.ico" />
    
    <!-- Fonts -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Aboreto&family=Cormorant+Garamond:wght@400;500;600&family=Montserrat:wght@300;400;500&display=swap" rel="stylesheet" />
  </head>
  <body class={`${themeBgClasses[color] || 'bg-bg'} text-text dark:text-text-dark antialiased transition-colors duration-300`}>
    <!-- Header -->
    <header class="fixed top-0 left-0 right-0 z-50 h-[62px] flex items-center justify-between px-6 md:px-12 bg-nav/70 dark:bg-nav-dark/80 backdrop-blur-[12px] border-b border-black/[0.06] dark:border-white/[0.12] transition-colors duration-300">
      <nav class="flex items-center gap-6 md:gap-8" aria-label="Nawigacja">
        <a href="/" class="font-montserrat text-sm font-medium hover:text-accent-blue transition-colors">Strona główna</a>
        <a href="/#projekty" class="font-montserrat text-sm font-medium hover:text-accent-blue transition-colors">Projekty</a>
      </nav>
      
      <button 
        id="theme-toggle" 
        class="w-10 h-10 rounded-full bg-surface-strong dark:bg-surface-strong-dark border border-surface-border dark:border-white/[0.12] flex items-center justify-center hover:scale-110 transition-transform"
        aria-label="Przełącz tryb ciemny"
      >
        <span id="theme-icon" class="text-lg">🌙</span>
      </button>
    </header>
    
    <!-- Spacer -->
    <div class="h-[62px]"></div>
    
    <main class="min-h-screen">
      <!-- Case Header -->
      <section class={`py-16 md:py-24 px-6 md:px-12 lg:px-20 ${colorClasses[color] || ''}`}>
        <div class="max-w-4xl mx-auto">
          <a href="/#projekty" class="inline-flex items-center gap-2 font-montserrat text-sm text-muted dark:text-gray-300 hover:text-accent-blue transition-colors mb-8">
            <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 19l-7-7m0 0l7-7m-7 7h18" />
            </svg>
            Powrót do projektów
          </a>
          
          <h1 class="font-aboreto text-4xl md:text-6xl text-text dark:text-text-dark mb-6">
            {title}
          </h1>
          
          <p class="font-montserrat text-lg md:text-xl text-muted dark:text-gray-300 mb-8">
            {subtitle}
          </p>
          
          <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
            {problem && (
              <div class="bg-surface-strong dark:bg-surface-strong-dark rounded-xl p-6 border border-surface-border dark:border-white/[0.12]">
                <h3 class="font-montserrat text-xs font-medium tracking-wider text-accent-blue mb-3">PROBLEM</h3>
                <p class="font-montserrat text-sm text-text dark:text-text-dark">{problem}</p>
              </div>
            )}
            
            {scope && (
              <div class="bg-surface-strong dark:bg-surface-strong-dark rounded-xl p-6 border border-surface-border dark:border-white/[0.12]">
                <h3 class="font-montserrat text-xs font-medium tracking-wider text-accent-blue mb-3">ZAKRES</h3>
                <p class="font-montserrat text-sm text-text dark:text-text-dark">{scope}</p>
              </div>
            )}
          </div>
          
          {reflection && (
            <div class="mt-6 bg-surface-strong dark:bg-surface-strong-dark rounded-xl p-6 border border-surface-border dark:border-white/[0.12]">
              <h3 class="font-montserrat text-xs font-medium tracking-wider text-accent-blue mb-3">WNIOSEK</h3>
              <p class="font-montserrat text-sm text-text dark:text-text-dark">{reflection}</p>
            </div>
          )}
        </div>
      </section>
      
      <!-- Case Images -->
      <section class="py-16 md:py-24 px-6 md:px-12 lg:px-20">
        <div class="max-w-5xl mx-auto space-y-8">
          {images.map((image, index) => (
            <div class="rounded-2xl overflow-hidden border border-surface-border dark:border-white/[0.12] shadow-lg">
              <img 
                src={image} 
                alt={`${title} - strona ${index + 1}`}
                class="w-full h-auto"
                loading={index < 2 ? 'eager' : 'lazy'}
              />
            </div>
          ))}
        </div>
      </section>
      
      <!-- Next Project -->
      <section class="py-16 px-6 md:px-12 lg:px-20 border-t border-black/[0.06] dark:border-white/[0.12]">
        <div class="max-w-4xl mx-auto text-center">
          <p class="font-montserrat text-sm text-muted dark:text-gray-300 mb-4">Chcesz zobaczyć więcej?</p>
          <a href="/#projekty" class="inline-flex items-center gap-2 font-montserrat text-lg font-medium text-text dark:text-text-dark hover:text-accent-blue transition-colors">
            Zobacz wszystkie projekty
            <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3" />
            </svg>
          </a>
        </div>
      </section>
    </main>
    
    <!-- Footer -->
    <footer class="py-12 px-6 md:px-12 border-t border-black/[0.06] dark:border-white/[0.12] bg-bg dark:bg-bg-dark transition-colors duration-300">
      <div class="max-w-6xl mx-auto flex flex-col md:flex-row items-center justify-between gap-4">
        <p class="font-montserrat text-sm text-muted dark:text-gray-300">
          © 2026 Paula Kordevych
        </p>
        <div class="flex items-center gap-6">
          <a href="mailto:kordevych.paula@gmail.com" class="font-montserrat text-sm hover:text-accent-blue transition-colors">
            Email
          </a>
          <a href="https://www.behance.net/paulakordevych" target="_blank" rel="noreferrer" class="font-montserrat text-sm hover:text-accent-blue transition-colors">
            Behance
          </a>
        </div>
      </div>
    </footer>
    
    <!-- Scroll to top -->
    <button id="scroll-top" class="fixed bottom-8 right-8 w-12 h-12 rounded-full bg-surface-strong dark:bg-surface-strong-dark border border-surface-border dark:border-white/[0.12] shadow-lg backdrop-blur-nav opacity-0 invisible transition-all duration-300 hover:scale-110 z-50" aria-label="Wróć do góry">
      <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 mx-auto" fill="none" viewBox="0 0 24 24" stroke="currentColor">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 10l7-7m0 0l7 7m-7-7v18" />
      </svg>
    </button>
    
    <script is:inline src="/scripts/theme.js"></script>
  </body>
</html>
