---
import Layout from '../../layouts/Layout.astro';

// SEO Description
const description = "Case study HawkTech - aplikacja e-commerce dla produktów gamingowych. Zobacz projekt UX/UI, architekturę informacji, system filtracji i visual design.";

// Import all case study images
const images = [
  { src: '/assets/projects/p3/new-case/CS - HawkTech_1.png', alt: 'HawkTech - Strona tytułowa' },
  { src: '/assets/projects/p3/new-case/CS - HawkTech_2.png', alt: 'HawkTech - Kontekst projektu' },
  { src: '/assets/projects/p3/new-case/CS - HawkTech_3.png', alt: 'HawkTech - Problem i cel' },
  { src: '/assets/projects/p3/new-case/CS - HawkTech_4.png', alt: 'HawkTech - Research' },
  { src: '/assets/projects/p3/new-case/CS - HawkTech_5.png', alt: 'HawkTech - User flow' },
  { src: '/assets/projects/p3/new-case/CS - HawkTech_6.png', alt: 'HawkTech - Architektura informacji' },
  { src: '/assets/projects/p3/new-case/CS - HawkTech_7.png', alt: 'HawkTech - UI Design' },
  { src: '/assets/projects/p3/new-case/CS - HawkTech_8.png', alt: 'HawkTech - Wnioski' },
];
---

<Layout title="HawkTech | Case Study" description={description}>
  <!-- Preload first image for faster initial paint -->
  <link rel="preload" as="image" href="/assets/projects/p3/new-case/CS - HawkTech_1.png" fetchpriority="high" slot="head" />
  <main class="bg-bg dark:bg-bg-dark min-h-screen">
    <!-- Hero Section - New Layout -->
    <section class="pt-6 sm:pt-8 pb-12 sm:pb-16 md:pb-24 px-4 sm:px-6 md:px-12 lg:px-20 bg-project-purple/30 overflow-x-hidden">
      <div class="max-w-6xl mx-auto">
        <!-- Back link -->
        <a href="/#projekty" class="inline-flex items-center gap-2 font-montserrat text-sm text-muted dark:text-gray-300 hover:text-accent-blue transition-colors mb-12 md:mb-16">
          <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 19l-7-7m0 0l7-7m-7 7h18" />
          </svg>
          Powrót do projektów
        </a>
        
        <!-- Main content grid -->
        <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 lg:gap-20 items-start mb-16">
          <!-- Left: Title -->
          <div>
            <h1 class="font-aboreto text-4xl sm:text-5xl md:text-7xl lg:text-8xl text-text dark:text-text-dark leading-none break-words">
              HawkTech
            </h1>
          </div>
          
          <!-- Right: Description -->
          <div class="lg:pt-4">
            <p class="font-montserrat text-lg md:text-xl text-muted dark:text-gray-300 leading-relaxed">
              Projekt UX/UI aplikacji e-commerce zaprojektowanej pod szybkie decyzje zakupowe.
            </p>
          </div>
        </div>
        
        <!-- Info boxes - horizontal layout -->
        <div class="grid grid-cols-1 md:grid-cols-2 gap-6 max-w-4xl">
          <!-- Problem box -->
          <div class="border-l-2 border-accent-blue pl-6 py-2">
            <p class="font-montserrat text-xs font-medium tracking-wider text-accent-blue mb-2 uppercase">Problem</p>
            <p class="font-montserrat text-base text-text dark:text-text-dark">Zakupy produktów gamingowych powinny być szybsze i bardziej intuicyjne</p>
          </div>
          
          <!-- Scope box -->
          <div class="border-l-2 border-accent-blue pl-6 py-2">
            <p class="font-montserrat text-xs font-medium tracking-wider text-accent-blue mb-2 uppercase">Zakres</p>
            <p class="font-montserrat text-base text-text dark:text-text-dark">UX/UI, architektura zakupowa, filtracja, visual system</p>
          </div>
        </div>
      </div>
    </section>

    <!-- Case Study Content with animations -->
    <section class="py-12 sm:py-16 md:py-24 px-4 sm:px-6 md:px-12 lg:px-20">
      <div class="max-w-5xl mx-auto space-y-8">
        {images.map((image, index) => (
          <div class="case-study-slide rounded-2xl overflow-hidden border border-surface-border dark:border-white/[0.12] shadow-lg opacity-0 translate-y-6 bg-surface-strong dark:bg-surface-strong-dark" data-slide-index={index}>
            <img
              src={image.src}
              alt={image.alt}
              class="w-full h-auto"
              loading={index < 2 ? 'eager' : 'lazy'}
              decoding={index < 2 ? 'sync' : 'async'}
              fetchpriority={index === 0 ? 'high' : 'auto'}
              width="1200"
              height="675"
              style="aspect-ratio: 16/9;"
            />
          </div>
        ))}
      </div>
    </section>

    <!-- Navigation -->
    <section class="py-12 sm:py-16 px-4 sm:px-6 md:px-12 lg:px-20 border-t border-black/[0.06] dark:border-white/[0.12]">
      <div class="max-w-4xl mx-auto flex flex-col md:flex-row items-center justify-between gap-6">
        <a href="/projects/pylio" class="inline-flex items-center gap-2 font-montserrat text-text dark:text-text-dark hover:text-accent-blue transition-colors">
          <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7" />
          </svg>
          Poprzedni projekt: Pylio
        </a>
        
        <a href="/#projekty" class="inline-flex items-center gap-2 font-cormorant text-xl text-text dark:text-text-dark hover:text-accent-blue transition-colors">
          Zobacz wszystkie projekty
        </a>
        
        <a href="/projects/nimbus" class="inline-flex items-center gap-2 font-montserrat text-text dark:text-text-dark hover:text-accent-blue transition-colors">
          Następny projekt: Nimbus
          <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" />
          </svg>
        </a>
      </div>
    </section>
  </main>

  <!-- Fade-in animation script -->
  <script>
    const observerOptions = {
      root: null,
      rootMargin: '0px 0px -50px 0px',
      threshold: 0.1
    };

    const slideObserver = new IntersectionObserver((entries) => {
      entries.forEach(entry => {
        if (entry.isIntersecting) {
          entry.target.classList.add('slide-visible');
          slideObserver.unobserve(entry.target);
        }
      });
    }, observerOptions);

    document.querySelectorAll('.case-study-slide').forEach((slide, index) => {
      slide.style.transitionDelay = `${index * 100}ms`;
      slideObserver.observe(slide);
    });
  </script>

  <style>
    .case-study-slide {
      transition: opacity 0.6s ease-out, transform 0.6s ease-out;
    }
    .case-study-slide.slide-visible {
      opacity: 1;
      transform: translateY(0);
    }
    @media (prefers-reduced-motion: reduce) {
      .case-study-slide {
        opacity: 1;
        transform: none;
        transition: none;
      }
    }
  </style>
</Layout>
