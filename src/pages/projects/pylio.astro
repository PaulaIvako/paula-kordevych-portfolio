---
import Layout from '../../layouts/Layout.astro';

// SEO Description
const description = "Case study aplikacji Pylio - projekt UX/UI pomagający osobom z alergią monitorować poziom pyłków. Zobacz proces research, user flow, architekturę informacji i finalny design.";

// Import all case study images
const images = [
  { src: '/assets/projects/p1/new-case/CS - Pylio_1.png', alt: 'Pylio - Strona tytułowa' },
  { src: '/assets/projects/p1/new-case/CS - Pylio_2.png', alt: 'Pylio - Kontekst projektu' },
  { src: '/assets/projects/p1/new-case/CS - Pylio_3.png', alt: 'Pylio - Problem i cel' },
  { src: '/assets/projects/p1/new-case/CS - Pylio_4.png', alt: 'Pylio - Użytkownik i Persona' },
  { src: '/assets/projects/p1/new-case/CS - Pylio_5.png', alt: 'Pylio - Cele UX' },
  { src: '/assets/projects/p1/new-case/CS - Pylio_6.png', alt: 'Pylio - User flow i wireframes' },
  { src: '/assets/projects/p1/new-case/CS - Pylio_7.png', alt: 'Pylio - Architektura informacji' },
  { src: '/assets/projects/p1/new-case/CS - Pylio_8.png', alt: 'Pylio - Kluczowe decyzje projektowe' },
  { src: '/assets/projects/p1/new-case/CS - Pylio_9.png', alt: 'Pylio - UI i spójność' },
  { src: '/assets/projects/p1/new-case/CS - Pylio_10.png', alt: 'Pylio - Kolor jako nośnik informacji' },
  { src: '/assets/projects/p1/new-case/CS - Pylio_11.png', alt: 'Pylio - Ikony i filtry' },
  { src: '/assets/projects/p1/new-case/CS - Pylio_12.png', alt: 'Pylio - Moja rola i wnioski' },
];
---

<Layout title="Pylio | Case Study" description={description}>
  <!-- Preload first image for faster initial paint -->
  <link rel="preload" as="image" href="/assets/projects/p1/new-case/CS - Pylio_1.png" fetchpriority="high" slot="head" />
  <main class="bg-bg dark:bg-bg-dark min-h-screen">
    <!-- Hero Section - New Layout -->
    <section class="pt-6 sm:pt-8 pb-12 sm:pb-16 md:pb-24 px-4 sm:px-6 md:px-12 lg:px-20 bg-project-yellow/30 overflow-x-hidden">
      <div class="max-w-6xl mx-auto">
        <!-- Back link -->
        <a href="/#projekty" class="inline-flex items-center gap-2 font-montserrat text-sm text-muted dark:text-gray-300 hover:text-accent-blue transition-colors mb-12 md:mb-16">
          <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 19l-7-7m0 0l7-7m-7 7h18" />
          </svg>
          Powrót do projektów
        </a>
        
        <!-- Main content grid -->
        <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 lg:gap-20 items-start mb-16">
          <!-- Left: Title -->
          <div>
            <h1 class="font-aboreto text-4xl sm:text-5xl md:text-7xl lg:text-8xl text-text dark:text-text-dark leading-none break-words">
              Pylio
            </h1>
          </div>
          
          <!-- Right: Description -->
          <div class="lg:pt-4">
            <p class="font-montserrat text-lg md:text-xl text-muted dark:text-gray-300 leading-relaxed">
              Aplikacja mobilna, która pomaga osobom z alergią monitorować poziom pyłków i podejmować codzienne decyzje na podstawie aktualnego ryzyka oraz objawów.
            </p>
          </div>
        </div>
        
        <!-- Info boxes - horizontal layout -->
        <div class="grid grid-cols-1 md:grid-cols-2 gap-6 max-w-4xl">
          <!-- Problem box -->
          <div class="border-l-2 border-accent-blue pl-6 py-2">
            <p class="font-montserrat text-xs font-medium tracking-wider text-accent-blue mb-2 uppercase">Problem</p>
            <p class="font-montserrat text-base text-text dark:text-text-dark">Jak uprościć interpretację danych o pyleniu i zamienić je w decyzję</p>
          </div>
          
          <!-- Scope box -->
          <div class="border-l-2 border-accent-blue pl-6 py-2">
            <p class="font-montserrat text-xs font-medium tracking-wider text-accent-blue mb-2 uppercase">Zakres</p>
            <p class="font-montserrat text-base text-text dark:text-text-dark">UX research, product thinking, flow, UI, design system</p>
          </div>
        </div>
      </div>
    </section>

    <!-- Case Study Content - edge to edge on mobile -->
    <section class="py-12 sm:py-16 md:py-24 px-0 sm:px-6 md:px-12 lg:px-20">
      <div class="max-w-full sm:max-w-5xl mx-auto space-y-4 sm:space-y-8">
        {images.map((image, index) => (
          <div class="sm:rounded-2xl overflow-hidden sm:border sm:border-surface-border dark:sm:border-white/[0.12] sm:shadow-lg bg-surface-strong dark:bg-surface-strong-dark">
            <img
              src={image.src}
              alt={image.alt}
              class="w-full h-auto object-contain"
              loading={index < 2 ? 'eager' : 'lazy'}
              decoding={index < 2 ? 'sync' : 'async'}
              fetchpriority={index === 0 ? 'high' : 'auto'}
            />
          </div>
        ))}
      </div>
    </section>

    <!-- Navigation -->
    <section class="py-12 sm:py-16 px-4 sm:px-6 md:px-12 lg:px-20 border-t border-black/[0.06] dark:border-white/[0.12]">
      <div class="max-w-4xl mx-auto flex flex-col md:flex-row items-center justify-between gap-6">
        <a href="/projects/nimbus" class="inline-flex items-center gap-2 font-montserrat text-text dark:text-text-dark hover:text-accent-blue transition-colors">
          <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7" />
          </svg>
          Poprzedni projekt: Nimbus
        </a>
        
        <a href="/#projekty" class="inline-flex items-center gap-2 font-cormorant text-xl text-text dark:text-text-dark hover:text-accent-blue transition-colors">
          Zobacz wszystkie projekty
        </a>
        
        <a href="/projects/hawktech" class="inline-flex items-center gap-2 font-montserrat text-text dark:text-text-dark hover:text-accent-blue transition-colors">
          Następny projekt: HawkTech
          <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" />
          </svg>
        </a>
      </div>
    </section>
  </main>
</Layout>
