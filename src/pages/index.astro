---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import Hero from '../components/sections/Hero.astro';
import Projects from '../components/sections/Projects.astro';
import Process from '../components/sections/Process.astro';
import Skills from '../components/sections/Skills.astro';
import About from '../components/sections/About.astro';
import POV from '../components/sections/POV.astro';
import Experience from '../components/sections/Experience.astro';
import Courses from '../components/sections/Courses.astro';
import Contact from '../components/sections/Contact.astro';
---

<Layout>
  <Header />
  
  <main class="bg-bg dark:bg-bg-dark min-h-screen transition-colors duration-300">
    <div class="max-w-layout mx-auto py-16 sm:py-22 px-4 sm:px-8 lg:px-12 overflow-x-hidden">
      <Hero />
      <Projects />
      <Process />
      <Skills />
      <About />
      <POV />
      <Experience />
      <Courses />
      <Contact />
    </div>
  </main>
  
  <Footer />
</Layout>
